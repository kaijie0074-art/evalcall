{
  "schema": "b2b-operations-design/v1",
  "version": "2026-07-16.4",
  "subject": {
    "product": "EvalCall",
    "audiences": ["模型评测运营", "模型工程师", "业务规则负责人"],
    "dashboard_job": "定位需要处理的评测任务并立即执行下一步动作",
    "interaction_model": "对象 → 状态 → 证据 → 动作 → 审计记录"
  },
  "design_principles": [
    {
      "id": "work_before_explanation",
      "name": "工作优先",
      "rule": "首页首屏直接展示状态、筛选、工作队列和下一步动作，不展示品牌宣言或方法论说理。",
      "test": "用户进入页面后无需滚动即可创建任务、继续运行或处理待办。"
    },
    {
      "id": "one_object_one_status_one_action",
      "name": "对象—状态—动作",
      "rule": "每一行只描述一个业务对象；状态靠近对象；主动作固定在行尾或详情面板底部。",
      "test": "扫读一行即可回答这是什么、现在怎样、下一步做什么。"
    },
    {
      "id": "queue_is_primary",
      "name": "队列是首页主体",
      "rule": "任务表或待办列表占据最大可用面积，摘要指标只能作为工具栏或紧凑状态条。",
      "test": "主列表面积不低于首页有效内容面积的 55%。"
    },
    {
      "id": "progressive_disclosure",
      "name": "渐进披露",
      "rule": "列表只保留识别和决策字段；证据、日志、版本指纹进入抽屉、详情或二级页。",
      "test": "默认任务表保持 6–8 列，单行高度 44–56px。"
    },
    {
      "id": "single_primary_action",
      "name": "单一主动作",
      "rule": "同一视口只保留一个视觉上最强的主按钮，重复入口使用链接、行点击或次级按钮。",
      "test": "页面首屏不出现两个同文案、同权重的主按钮。"
    },
    {
      "id": "semantic_color_only",
      "name": "颜色只表达状态",
      "rule": "品牌黄只用于主动作、选中态和同尺锁定；红绿仅用于风险和通过，不用于装饰。",
      "test": "去除状态后页面主体仍以中性色为主。"
    },
    {
      "id": "stable_shell",
      "name": "稳定产品壳",
      "rule": "主导航、工作区上下文和用户入口位置稳定；页面切换只替换主内容。",
      "test": "用户从任务列表进入复核后，仍能一键返回原任务和原筛选。"
    },
    {
      "id": "audit_is_context",
      "name": "证据贴近判断",
      "rule": "证据与裁判结论在同一工作上下文展示，不通过大段解释代替原始证据。",
      "test": "复核页无需跳出即可看到样本、分歧、证据和最终动作。"
    }
  ],
  "anti_patterns": [
    {
      "id": "marketing_hero",
      "name": "营销式 Hero",
      "examples": ["先统一测试条件，再讨论模型是否真的提升", "大标题 + 价值解释 + 两个 CTA"],
      "replacement": "24px 页面标题 + 运行状态/更新时间 + 单一主动作"
    },
    {
      "id": "decorative_eyebrow",
      "name": "装饰性英文眉题",
      "examples": ["EVALUATION COMMAND CENTER", "MODEL EVALUATION CONTROL PLANE"],
      "replacement": "面包屑、任务编号或工作区名称；没有导航意义时直接删除"
    },
    {
      "id": "duplicate_cta",
      "name": "重复主动作",
      "examples": ["导航、页头、Hero、表格工具栏同时出现创建评测"],
      "replacement": "页头保留创建按钮，其他位置使用空状态或快捷键提示"
    },
    {
      "id": "kpi_card_wall",
      "name": "指标卡墙",
      "examples": ["四张等权大卡占据列表上方"],
      "replacement": "紧凑摘要条或与筛选工具栏合并"
    },
    {
      "id": "process_as_homepage",
      "name": "流程图占据首页",
      "examples": ["在任务中心展示完整评测方法论或技术架构"],
      "replacement": "流程只出现在具体任务的运行详情"
    }
  ],
