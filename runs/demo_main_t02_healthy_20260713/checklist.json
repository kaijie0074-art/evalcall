  },
  {
    "id": "system_1",
    "type": "constraint",
    "text": "应当只使用指令规定的 A、B、C、D 四项系统能力。",
    "source_quote": "系统能力只有四项：",
    "severity": "critical",
    "needs_review": false,
    "keywords": [],
    "safety": false,
    "policy_source": ""
  },
  {
    "id": "system_2",
    "type": "constraint",
    "text": "所有答复应当仅依据本通电话中的系统返回。",
    "source_quote": "你只能依据本通系统返回作答",
    "severity": "critical",
    "needs_review": false,
    "keywords": [],
    "safety": false,
    "policy_source": ""
  },
  {
    "id": "forbid_1",
    "type": "forbidden",
    "text": "不得编造订单、配送时段或处理结果。",
    "source_quote": "不得编造订单、时段或处理结果",
    "severity": "critical",
    "needs_review": false,
    "keywords": [
      "编造订单",
