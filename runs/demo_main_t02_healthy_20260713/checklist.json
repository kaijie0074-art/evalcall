    ],
    "safety": false,
    "policy_source": ""
  },
  {
    "id": "forbid_2",
    "type": "forbidden",
    "text": "不得索取用户的完整手机号。",
    "source_quote": "不得索取完整手机号、完整订单号、验证码、\n地址、身份证号或银行卡号。",
